#!/usr/bin/env bash
# Magic Hat — Server Management CLI
# Copyright (c) 2026 George Scott Foley — MIT License
#
# Usage: magichat <command>

set -euo pipefail

VERSION="0.1.0"
ENV_FILE="/etc/magichat/reflection.env"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'
BOLD='\033[1m'

_header() {
    echo -e "${CYAN}"
    echo "  ╔═══════════════════════════════════╗"
    echo "  ║         🎩  Magic Hat v${VERSION}      ║"
    echo "  ║    Familiar AI Server Platform    ║"
    echo "  ╚═══════════════════════════════════╝"
    echo -e "${NC}"
}

_check_service() {
    local svc=$1
    if systemctl is-active --quiet "$svc" 2>/dev/null; then
        echo -e "  ${GREEN}●${NC} $svc"
    else
        echo -e "  ${RED}●${NC} $svc"
    fi
}

cmd_status() {
    _header
    echo -e "${BOLD}Services:${NC}"
    _check_service "reflection"
    _check_service "postgresql"
    _check_service "redis"
    _check_service "nginx"
    _check_service "fail2ban"
    echo ""

    echo -e "${BOLD}System:${NC}"
    echo "  Uptime:  $(uptime -p)"
    echo "  Memory:  $(free -h | awk '/^Mem:/ {printf "%s / %s (%.0f%%)", $3, $2, $3/$2*100}')"
    echo "  Disk:    $(df -h / | awk 'NR==2 {printf "%s / %s (%s)", $3, $2, $5}')"
    echo "  SELinux: $(getenforce 2>/dev/null || echo 'N/A')"
    echo ""

    if systemctl is-active --quiet reflection; then
        echo -e "${BOLD}Reflection:${NC}"
        local port=$(grep REFLECTION_PORT "${ENV_FILE}" 2>/dev/null | cut -d= -f2 || echo "8000")
        local health=$(curl -sf "http://127.0.0.1:${port}/health" 2>/dev/null | python3.11 -m json.tool 2>/dev/null || echo "unreachable")
        echo "  Health: ${health}"
    fi

    echo ""
    echo -e "${BOLD}Backups:${NC}"
    local latest=$(ls -1t /var/backups/magichat/reflection-*.sql.gz* 2>/dev/null | head -1)
    if [[ -n "${latest:-}" ]]; then
        echo "  Latest: $(basename "${latest}") ($(du -h "${latest}" | cut -f1))"
        echo "  Count:  $(ls -1 /var/backups/magichat/reflection-*.sql.gz* 2>/dev/null | wc -l) daily, $(ls -1 /var/backups/magichat/weekly/reflection-*.sql.gz* 2>/dev/null | wc -l) weekly"
    else
        echo "  No backups yet (runs daily at 03:00)"
    fi
    echo ""
}

cmd_setup() {
    _header
    echo -e "${BOLD}Server Setup${NC}"
    echo ""

    read -p "  Domain name (e.g., ai.example.com): " DOMAIN
    if [[ -z "${DOMAIN}" ]]; then
        echo "Error: Domain is required."
        exit 1
    fi

    echo ""
    echo "  Configuring domain: ${DOMAIN}"

    # Update Nginx server_name
    sed -i "s/server_name _;/server_name ${DOMAIN};/g" /etc/nginx/conf.d/reflection.conf
    hostnamectl set-hostname "${DOMAIN}"

    # Request TLS cert
    echo ""
    read -p "  Set up Let's Encrypt TLS? [Y/n] " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Nn]$ ]]; then
        read -p "  Email for Let's Encrypt: " EMAIL
        certbot --nginx -d "${DOMAIN}" --non-interactive --agree-tos -m "${EMAIL}" --redirect
        echo -e "  ${GREEN}TLS configured!${NC}"
    fi

    systemctl reload nginx
    echo ""
    echo -e "  ${GREEN}Setup complete!${NC} Your server is at: https://${DOMAIN}"
    echo ""
}

cmd_admin() {
    _header
    echo -e "${BOLD}Create Admin User${NC}"
    echo ""

    read -p "  Admin email: " ADMIN_EMAIL
    read -sp "  Admin password: " ADMIN_PASS
    echo ""

    python3.11 -m reflection admin create-user \
        --email "${ADMIN_EMAIL}" \
        --password "${ADMIN_PASS}" \
        --role admin

    echo -e "  ${GREEN}Admin user created!${NC}"
    echo ""
}

cmd_logs() {
    local service="${1:-reflection}"
    journalctl -u "${service}" -f --no-hostname
}

cmd_restart() {
    echo "Restarting Magic Hat services..."
    systemctl restart reflection
    systemctl reload nginx
    echo -e "${GREEN}Done.${NC}"
}

cmd_stop() {
    echo "Stopping Reflection..."
    systemctl stop reflection
    echo -e "${YELLOW}Reflection stopped.${NC} PostgreSQL and Redis still running."
}

cmd_start() {
    echo "Starting Reflection..."
    systemctl start reflection
    echo -e "${GREEN}Reflection started.${NC}"
}

cmd_update() {
    _header
    echo "Updating Magic Hat..."
    echo ""

    echo "[1/3] Updating system packages..."
    dnf upgrade -y --security

    echo "[2/3] Updating Reflection..."
    python3.11 -m pip install --upgrade "reflection-agent[full]"

    echo "[3/3] Running database migrations..."
    sudo -u magichat python3.11 -m reflection migrate

    echo ""
    echo "Restarting services..."
    systemctl restart reflection
    systemctl reload nginx

    echo ""
    echo -e "${GREEN}Update complete!${NC}"
    cmd_status
}

cmd_backup() {
    echo "Running backup..."
    /opt/magichat/scripts/backup.sh
}

cmd_harden() {
    _header
    echo -e "${BOLD}Security Hardening Audit${NC}"
    echo ""
    if [[ -f /opt/magichat/security/hardening.sh ]]; then
        /opt/magichat/security/hardening.sh "${1:-}"
    else
        echo -e "  ${RED}Error:${NC} Hardening script not found at /opt/magichat/security/hardening.sh"
        echo "  Run the installer or download from the repo."
    fi
}

cmd_audit_log() {
    _header
    echo -e "${BOLD}Security Audit Log${NC}"
    echo ""
    echo -e "${BOLD}Recent auth failures:${NC}"
    journalctl -u sshd --since "24 hours ago" --grep "Failed\|Invalid" --no-pager -q 2>/dev/null | tail -20 || echo "  None"
    echo ""
    echo -e "${BOLD}Recent fail2ban actions:${NC}"
    journalctl -u fail2ban --since "24 hours ago" --no-pager -q 2>/dev/null | grep -i "ban\|unban" | tail -20 || echo "  None"
    echo ""
    echo -e "${BOLD}Recent auditd alerts:${NC}"
    ausearch -ts recent -m avc -m user_auth 2>/dev/null | tail -20 || echo "  None (auditd may not be running)"
    echo ""
    echo -e "${BOLD}AIDE file integrity:${NC}"
    if [[ -f /var/lib/aide/aide.db.gz ]]; then
        echo "  Database present. Run 'aide --check' for full report."
        local last_check
        last_check=$(stat -c %Y /var/lib/aide/aide.db.gz 2>/dev/null)
        if [[ -n "$last_check" ]]; then
            echo "  Last baseline: $(date -d "@${last_check}" '+%Y-%m-%d %H:%M')"
        fi
    else
        echo "  No AIDE database. Run 'aide --init' to create baseline."
    fi
    echo ""
}

cmd_help() {
    _header
    echo "Usage: magichat <command>"
    echo ""
    echo "Commands:"
    echo "  status    Show server status"
    echo "  setup     Configure domain + TLS (first-time)"
    echo "  admin     Create admin user"
    echo "  start     Start Reflection"
    echo "  stop      Stop Reflection"
    echo "  restart   Restart all services"
    echo "  update    Update OS + Reflection + run migrations"
    echo "  backup    Run database backup now"
    echo "  logs      Follow service logs (default: reflection)"
    echo "  harden    Run security hardening audit (--apply to fix)"
    echo "  audit     Show security audit log (24h)"
    echo "  help      Show this help"
    echo ""
}

# ── Main ─────────────────────────────────────────────────────────────────────
case "${1:-help}" in
    status)   cmd_status ;;
    setup)    cmd_setup ;;
    admin)    cmd_admin ;;
    start)    cmd_start ;;
    stop)     cmd_stop ;;
    restart)  cmd_restart ;;
    update)   cmd_update ;;
    backup)   cmd_backup ;;
    logs)     cmd_logs "${2:-reflection}" ;;
    harden)   cmd_harden "${2:-}" ;;
    audit)    cmd_audit_log ;;
    help|-h|--help) cmd_help ;;
    version|-v|--version) echo "Magic Hat v${VERSION}" ;;
    *)
        echo "Unknown command: $1"
        cmd_help
        exit 1
        ;;
esac
